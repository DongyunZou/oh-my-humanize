---
name: parallel-weak-implementation
version: 1
schema: omhflow/v1
models:
  roles:
    builder: gpt-5.5
    reviewer: gpt-5.5
  defaults:
    agent: builder
    review: reviewer
  unavailable: fallback-to-parent
checkpoint:
  stopDeadlineMs: 300000
changePolicy:
  agentsCanPropose: true
  humansCanApprove: true
---
# Parallel weak implementation

```yaml workflow
resources:
  - path: prompts/scope.md
    kind: prompt
  - path: prompts/implement-core.md
    kind: prompt
  - path: prompts/implement-tests.md
    kind: prompt
  - path: prompts/implement-docs.md
    kind: prompt
  - path: prompts/weak-review.md
    kind: prompt
capabilities:
  agents:
    - task
    - reviewer
sequence:
  - node:
      id: scope
      type: agent
      agent: task
      model:
        role: builder
      prompt:
        file: prompts/scope.md
      writes:
        - /plan
  - parallel:
      - node:
          id: implementCore
          type: agent
          agent: task
          model:
            role: builder
          reads:
            - /plan
          prompt:
            template:
              file: prompts/implement-core.md
              bindings:
                plan:
                  state: /plan
      - node:
          id: implementTests
          type: agent
          agent: task
          model:
            role: builder
          reads:
            - /plan
          prompt:
            template:
              file: prompts/implement-tests.md
              bindings:
                plan:
                  state: /plan
      - node:
          id: implementDocs
          type: agent
          agent: task
          model:
            role: builder
          reads:
            - /plan
          prompt:
            template:
              file: prompts/implement-docs.md
              bindings:
                plan:
                  state: /plan
    join:
      id: weakReview
      type: review
      agent: reviewer
      model:
        role: reviewer
      reads:
        - /plan
      prompt:
        template:
          file: prompts/weak-review.md
          bindings:
            plan:
              state: /plan
      gates:
        - continue
        - finish
```
